graph.mazhuoran.cloud {
    @websocket {
        header Connection *Upgrade*
        path /api/v1/ws/*
    }
    reverse_proxy @websocket backend:8000 {
        header_up Connection {>Connection}
        header_up Upgrade {>Upgrade}
    }

    handle /api/* {
        reverse_proxy backend:8000
    }
    handle /docs* {
        reverse_proxy backend:8000
    }
    handle /openapi.json* {
        reverse_proxy backend:8000
    }
    handle /health* {
        reverse_proxy backend:8000
    }
    reverse_proxy frontend:3000
}
