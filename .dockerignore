# Dependencies
node_modules/
__pycache__/
*.pyc
.venv/
venv/
*.egg-info/

# Build outputs
.next/
out/
dist/
build/

# Git
.git/
.gitignore

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

