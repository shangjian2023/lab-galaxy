# ── Domain ──
DOMAIN=yourdomain.com

# ── PostgreSQL ──
POSTGRES_PASSWORD=change-this-to-a-strong-password

# ── Neo4j ──
NEO4J_PASSWORD=change-this-to-a-strong-password

# ── MinIO ──
MINIO_ACCESS_KEY=change-this-access-key
MINIO_SECRET_KEY=change-this-secret-key

# ── Backend Auth ──
SECRET_KEY=change-this-to-a-random-64-char-string

# ── LLM (DeepSeek / OpenAI Compatible) ──
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-your-deepseek-api-key
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_MODEL=deepseek-v4-pro

# ── Logging ──
LOG_LEVEL=INFO
