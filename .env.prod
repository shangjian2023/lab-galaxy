# ── Domain ──
DOMAIN=graph.mazhuoran.cloud

# ── Passwords (generated on server during deploy) ──
POSTGRES_PASSWORD=<generated-on-server>
NEO4J_PASSWORD=<generated-on-server>
MINIO_ACCESS_KEY=<generated-on-server>
MINIO_SECRET_KEY=<generated-on-server>
SECRET_KEY=<generated-on-server>

# ── LLM (SiliconFlow) ──
LLM_PROVIDER=openai
OPENAI_API_KEY=<your-api-key>
OPENAI_BASE_URL=https://api.siliconflow.cn/v1
OPENAI_MODEL=Qwen/Qwen3.6-27B

# ── Logging ──
LOG_LEVEL=INFO
